# WikiRAG environment variables
# Copy this file and fill in real values — never commit secrets.

# --- Service ports (host-side) ---
API_PORT=8000

# --- Qdrant ---
QDRANT_HOST=qdrant
QDRANT_PORT=6333
QDRANT_COLLECTION=wikipedia

# --- Redis ---
REDIS_HOST=redis
REDIS_PORT=6379
CHUNK_CACHE_TTL=86400   # 24 hours in seconds
ANSWER_CACHE_TTL=21600  # 6 hours in seconds

# --- Embedder (Ollama) ---
EMBEDDER_HOST=embedder
EMBEDDER_PORT=11434
EMBED_MODEL=nomic-embed-text:v1.5

# --- Ingestion ---
WIKI_DUMP_URL=https://dumps.wikimedia.org/other/cirrussearch/20251229/enwiki-20251229-cirrussearch-content.json.gz
PAGEVIEW_TOP_FRACTION=0.15
MIN_ARTICLE_TOKENS=300
EMBED_BATCH_SIZE=64
DUMP_PATH=/data/wiki_dump.json.gz
